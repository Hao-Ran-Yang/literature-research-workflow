{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://codex.local/literature-research-workflow/accepted_artifacts.schema.json",
  "title": "Accepted Literature Artifacts Registry",
  "description": "Current-only contract for batches/accepted_artifacts.json. Registries are structured v2 objects; artifact lifecycle is controlled by status.",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "version": {
      "type": ["integer", "string"]
    },
    "artifacts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/artifactEntry"
      }
    }
  },
  "$defs": {
    "artifactEntry": {
      "type": "object",
      "additionalProperties": true,
      "required": ["type", "path", "status"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["note", "overview", "candidate_table", "final_report", "failure", "other"]
        },
        "artifact_type": {
          "type": "string"
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "batch": {
          "type": "string"
        },
        "artifact_label": {
          "type": "string"
        },
        "micro_batch": {
          "type": "string"
        },
        "paper_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "content_hash": {
          "type": "string"
        },
        "review_status": {
          "type": "string",
          "enum": ["clean", "accepted", "accepted_with_warnings", "warning", "failed", "unknown"]
        },
        "warning_codes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "source_candidate_table": {
          "type": "string"
        },
        "source_deep_manifest": {
          "type": "string"
        },
        "quality_status": {
          "type": "string",
          "enum": ["accepted", "warning", "failed", "superseded", "unknown"]
        },
        "status": {
          "type": "string",
          "enum": ["active", "superseded", "archived"]
        },
        "registered_at": {
          "type": "string"
        },
        "supersedes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "notes": {
          "type": "string"
        }
      }
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://codex.local/literature-research-workflow/deep_reading_candidate.schema.json",
  "title": "Reading-Priority Candidate Row",
  "description": "Advisory row-level contract for reading-priority candidate tables. Historical phase2_deep_reading_candidates.csv filenames remain valid for compatibility.",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "paper_id": { "type": ["string", "null"] },
    "title": { "type": ["string", "null"] },
    "technical_route": { "type": ["string", "null"] },
    "read_priority": { "type": ["string", "null"], "enum": ["high", "medium", "low", "skip", "", null] },
    "read_reason": { "type": ["string", "null"] },
    "first_sections_to_read": { "type": ["string", "null"] },
    "possible_gpt_question": { "type": ["string", "null"] },
    "deep_note_candidate": { "type": ["string", "null"], "enum": ["yes", "maybe", "no", "", null] },
    "deep_note_reason": { "type": ["string", "null"] },
    "arxiv_id": { "type": ["string", "null"] },
    "reading_batch": { "type": ["string", "null"] },
    "recommendation": { "type": ["string", "null"], "enum": ["yes", "maybe", "no", "", null] },
    "recommendation_reason": { "type": ["string", "null"] },
    "evidence_strength": { "type": ["string", "null"] },
    "selected_for_phase3": { "type": ["string", "null"], "enum": ["yes", "no", "", null] },
    "selection_notes": { "type": ["string", "null"] }
  }
}
